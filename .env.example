# Copy to .env and set your bot token (do not commit .env)
DISCORD_TOKEN=your_bot_token_here
# Optional: custom word list path
# WORDS_FILE=words.txt
# Optional: channel where the bot should listen (right-click channel → Copy ID). If not set, uses hardcoded gv-general ID.
# TRIGGER_CHANNEL_ID=1166738417539887218
# Optional: set to 1 or true to log why messages were skipped (wrong channel, empty content, safe-context, no trigger word)
# DEBUG=1

# Slur response: bot replies with this video (first offense). Use a direct, playable URL (e.g. from your host or CDN).
# If set, VIDEO_URL is used; otherwise VIDEO_PATH (local file path) is used.
# VIDEO_URL=https://example.com/path/to/TMFIAR.mp4
# VIDEO_PATH=C:\Users\serje\Downloads\TMFIAR.mp4
