# Copy to .env and set your bot token (do not commit .env)
DISCORD_TOKEN=your_bot_token_here
# Optional: custom word list path
# WORDS_FILE=words.txt
# Channel where the bot LISTENS (slurs, off-topic, religion/politics, Soon) = gv-general. Leave unset to use default. Do NOT set to off-topic.
# TRIGGER_CHANNEL_ID=1166738417539887218
# Optional: set to 1 or true to log why messages were skipped (wrong channel, empty content, safe-context, no trigger word)
# DEBUG=1

# Slur response: bot replies with this video (first offense). Use a direct, playable URL (e.g. from your host or CDN).
# If set, VIDEO_URL is used; otherwise VIDEO_PATH (local file path) is used.
# VIDEO_URL=https://example.com/path/to/TMFIAR.mp4
# VIDEO_PATH=C:\Users\serje\Downloads\TMFIAR.mp4

# New member join: post this video in gv-general (default: Knights with sub)
# NEW_ARRIVAL_VIDEO_URL=https://streamable.com/vxi8bu
# Channel to post the welcome video (default: same as TRIGGER_CHANNEL_ID / gv-general)
# GV_GENERAL_CHANNEL_ID=1166738417539887218
# Admin channel that receives join notifications; bot welcomes mentioned user in gv-general when it sees "joined"/"welcome" there
# ADMIN_JOIN_CHANNEL_ID=1166746316999757864

# User ID whose image/GIF posts in off-topic are moved to gv-general. Set in Render only — do not commit real IDs.
# OFFTOPIC_TO_GENERAL_USER_ID=
